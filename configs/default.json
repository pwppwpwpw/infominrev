{
  "seed": 42,
  "device": "cuda",
  "data": {
    "content_dir": "/path/to/content",
    "style_dir": "/path/to/style",
    "image_size": 512,
    "crop_size": 256,
    "batch_size": 4,
    "num_workers": 8,
    "pin_memory": true
  },
  "model": {
    "in_channels": 3,
    "pad_channels": 5,
    "num_blocks": 20,
    "num_squeeze": 2,
    "hidden_channels": 512,
    "blocks_per_stage": [7, 7, 6]
  },
  "loss": {
    "content_weight": 1.0,
    "style_weight": 10.0,
    "barlow_weight": 0.02,
    "mi_weight": 0.1,
    "jsd": {
      "warmup_steps": 2000,
      "eps": 1e-8
    },
    "barlow": {
      "lambda_offdiag": 0.0051,
      "eps": 1e-6,
      "layer": "relu4_1",
      "projector_dims": [512, 256, 128]
    },
    "mi": {
      "bandwidth": 1.0,
      "pool": 4,
      "max_dim": 1024
    }
  },
  "optim": {
    "lr": 0.0001,
    "betas": [0.9, 0.999],
    "weight_decay": 0.0
  },
  "train": {
    "max_iter": 160000,
    "log_every": 50,
    "save_every": 10000,
    "sample_every": 500,
    "output_dir": "./runs/infominrev",
    "resume": null
  },
  "vgg": {
    "weights": "model/vgg_normalised.pth",
    "layers": ["relu1_1", "relu2_1", "relu3_1", "relu4_1", "relu4_2"]
  }
}
